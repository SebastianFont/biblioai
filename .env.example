# Copiá este archivo a `.env` y completá los valores.
# `.env` está ignorado por git: nunca subas secretos al repo.

# --- Base de datos ---
# SQLite para desarrollo local (no requiere instalar nada).
DATABASE_URL="file:./dev.db"

# --- IA ---
# Proveedor del analizador de reseñas:
#   mock   -> determinista, sin costo, sin credenciales (por defecto, ideal para CI).
#   claude -> usa el Claude Agent SDK con tu suscripción de Claude Code (sin API key).
AI_PROVIDER="mock"

# Modelo a usar cuando AI_PROVIDER=claude (opcional, por defecto "haiku").
AI_MODEL="haiku"

# Solo si quisieras forzar el uso de la API paga de Anthropic en lugar de la
# suscripción. NO es necesario para AI_PROVIDER=claude vía Claude Code.
# ANTHROPIC_API_KEY=""

# --- Autenticación ---
# La app es single-user por diseño (usuario demo del seed), así que no se usa
# ninguna variable de auth. Si en el futuro se sumara Auth.js, acá iría su
# secreto: AUTH_SECRET (generable con `npx auth secret`).
